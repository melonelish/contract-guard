# ═══════════════════════════════════════════════════════════
# ContractGuard — Environment Variables Template
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values.
# cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── Application ──
APP_NAME=ContractGuard
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── LLM Models ──
# Primary: MiMo 2.5 (legal analysis)
MIMO_API_KEY=sk-your-mimo-api-key
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-2.5

# Backup: DeepSeek V4-Flash (cost-efficient for simpler tasks)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# Embedding
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=sk-your-embedding-api-key

# ── Database ──
DATABASE_URL=postgresql://contractguard:changeme@localhost:5432/contractguard
DATABASE_MAX_CONNECTIONS=20

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_MAX_LEN=10000

# ── Elasticsearch ──
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=contractguard

# ── Milvus (Vector DB) ──
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=laws_and_cases

# ── MinIO (File Storage) ──
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=contractguard-uploads
MINIO_SECURE=false

# ── Vault (Secret Management) ──
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root-token-change-me
VAULT_BACKEND_PATH=contractguard

# ── Auth ──
# ⚠️ 开发环境使用 HS256（对称签名，密钥泄露即可伪造任意 Token）
# 生产环境必须切换 RS256（非对称：私钥签名，公钥验证，公钥泄露不影响安全性）
JWT_SECRET=change-me-jwt-secret
JWT_ALGORITHM=HS256
# 生产 RS256 配置:
# JWT_ALGORITHM=RS256
# JWT_PRIVATE_KEY_PATH=/etc/contractguard/jwt_private.pem
# JWT_PUBLIC_KEY_PATH=/etc/contractguard/jwt_public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── WeChat (Mini Program) ──
WECHAT_APP_ID=your-app-id
WECHAT_APP_SECRET=your-app-secret

# ── Monitoring ──
PROMETHEUS_METRICS_PORT=9090
SENTRY_DSN=
